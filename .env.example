# Firebase — opcional (a config também pode ficar direto em src/lib/firebase.js).
# Defina na Vercel se preferir manter fora do código.
NEXT_PUBLIC_FIREBASE_API_KEY=xxxx
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=seu-projeto.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=seu-projeto
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=seu-projeto.appspot.com
NEXT_PUBLIC_FIREBASE_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxx

# Mercado Pago — SECRETO, definir SOMENTE na Vercel (nunca no código/commit)
MP_ACCESS_TOKEN=APP_USR-xxxxxxxx

